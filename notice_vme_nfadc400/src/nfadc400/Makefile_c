FILENAME = NoticeNFADC400
LIBname  = libNoticeNFADC400_c.so
CC       = gcc
CFLAGS   = -fPIC -O2 -Wall -DNKC -I. -I$(NKHOME)/include
LDFLAGS  = -shared

all: $(LIBname)

$(LIBname): $(FILENAME).o
	# Links against Notice6UVME_c and linux_interface_c
	$(CC) $(LDFLAGS) -o $@ $^ -L$(NKHOME)/lib -lNotice6UVME_c -llinux_interface_c
	@echo "Installing $(LIBname) to $(NKHOME)/lib"
	cp $(LIBname) $(NKHOME)/lib/
	cp $(FILENAME).h $(NKHOME)/include/

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f *.o *.so