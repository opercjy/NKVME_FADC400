########################################################################
#   Notice Korea    6UVME C++ Library                    
########################################################################
#   NKHOME should be defined by notice_env.sh

FILENAME = Notice6UVME

LIB	=	lib$(FILENAME)_cpp.so

CC	=	g++

# [핵심] -DNKCPP 옵션을 켜서 C++ 클래스로 컴파일되게 함
COPTS	=	-fPIC -DLINUX -Wall -DNKCPP

# [수정됨] -Wall,-soname -> -Wl,-soname,$(LIB)
FLAGS	=	-shared -Wl,-soname,$(LIB) -nostartfiles -s

LIBS	=	-L$(NKHOME)/lib -llinux_interface_c

INCLUDEDIR =	-I$(NKHOME)/include

INSTALLDIR     =	$(NKHOME)/lib
INSTALLINCLUDE =	$(NKHOME)/include

OBJS	=	$(FILENAME).o

INCLUDES =	$(FILENAME).h 

#########################################################################

all	:	$(LIB)

clean	:
		/bin/rm -f $(OBJS) $(LIB)

install	:	$(LIB)
		/bin/rm -f $(INSTALLDIR)/$(LIB)
		/bin/rm -f $(INSTALLINCLUDE)/$(FILENAME).h
		install $(LIB) $(INSTALLDIR)
		install $(FILENAME).h $(INSTALLINCLUDE)

$(LIB)	:	$(OBJS)
		$(CC) $(FLAGS) -o $(LIB) $(OBJS) $(LIBS)

$(OBJS)	:	$(INCLUDES) 

%.o	:	%.c
		$(CC) $(COPTS) $(INCLUDEDIR) -c -o $@ $<