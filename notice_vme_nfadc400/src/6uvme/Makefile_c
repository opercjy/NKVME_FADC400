# Makefile for 6uvme (C Library)
FILENAME = Notice6UVME
LIBname  = libNotice6UVME_c.so

CC       = gcc
# NKC 매크로를 정의하여 C 코드로 컴파일
CFLAGS   = -fPIC -O2 -Wall -DNKC -I. -I$(NKHOME)/include
LDFLAGS  = -shared

all: $(LIBname)

$(LIBname): $(FILENAME).o
	# linux_interface 라이브러리와 링크
	$(CC) $(LDFLAGS) -o $@ $^ -L$(NKHOME)/lib -llinux_interface_c
	@echo "Installing $(LIBname) to $(NKHOME)/lib"
	cp $(LIBname) $(NKHOME)/lib/
	cp $(FILENAME).h $(NKHOME)/include/

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f *.o *.so