# Makefile for linux_interface (C Library)
# Generates liblinux_interface_c.so

FILENAME = NKUSBVME_Linux
LIBname  = liblinux_interface_c.so

CC       = gcc
CFLAGS   = -fPIC -O2 -Wall
LDFLAGS  = -shared

INCLUDES = -I.

all: $(LIBname)

$(LIBname): $(FILENAME).o
	$(CC) $(LDFLAGS) -o $@ $^
	@echo "Installing $(LIBname) to $(NKHOME)/lib"
	cp $(LIBname) $(NKHOME)/lib/
	cp $(FILENAME).h $(NKHOME)/include/

%.o: %.c
	$(CC) $(CFLAGS) $(INCLUDES) -c $< -o $@

clean:
	rm -f *.o *.so