# ====================================================================
# VME FADC400 DAQ Configuration File (2-Board, 8-Channel Mode)
# ====================================================================

# 1. Run Information
RUNNUM  103
RUNTYP  TEST
RUNDSC  "FADC400 2-Board 8-Channel Setup (MID 0 & MID 1)"
SHIFT   "Operator"

# ====================================================================
# 2. FADC Board Setup
# FADC [MID] [NCH] [CH_ID 1] [CH_ID 2] ...
# ====================================================================
# MID 0번: 4채널 사용 (0, 1, 2, 3)
FADC    0    4     0 1 2 3
# MID 1번: 4채널 사용 (0, 1, 2, 3)
FADC    1    4     0 1 2 3

# ====================================================================
# 3. Global Settings & Trigger Logic (TLT)
# ====================================================================
NDP     0    512
NDP     1    512

# 0xFFFE = 해당 보드의 아무 채널이나 신호가 오면 트리거 (OR Trigger)
TLT     0    0xFFFE
TLT     1    0xFFFE

# ====================================================================
# 4. Channel Settings (Per Board)
# 형식: [명령어] [MID] [Ch0값] [Ch1값] [Ch2값] [Ch3값]
# ====================================================================

# [임계값 Threshold]
THR     0    10 10 10 10
THR     1    10 10 10 10

# [신호 극성 Polarity - 1:Negative(PMT), 0:Positive]
POL     0    1 1 1 1
POL     1    1 1 1 1

# [베이스라인 오프셋 DACOFF - Negative는 3400 부근]
DACOFF  0    3400 3400 3400 3400
DACOFF  1    3400 3400 3400 3400

# [트리거 지연 Delay (ns)]
DLY     0    800 800 800 800
DLY     1    800 800 800 800

END
